[Desktop Entry]
Type=Application
Name=Night Light
GenericName=Color Temperature
Comment=Warm the screen color temperature on a schedule
Exec=cosmic-nightlight
Icon=weather-clear-night-symbolic
Terminal=false
Categories=Utility;Settings;DesktopSettings;
Keywords=night;light;shift;redshift;gamma;color;temperature;blue;warm;
StartupNotify=true
StartupWMClass=io.github.cosmic_nightlight
# Marks this as a COSMIC panel applet so it appears in the panel/dock applet
# picker. NoDisplay keeps it out of the regular app launcher (launching the
# applet outside the panel has no anchor); use the Settings entry instead.
X-CosmicApplet=true
NoDisplay=true
