[Desktop Entry]
Type=Application
Name=Night Shift
GenericName=Night Light
Comment=Warm the screen color temperature on a schedule
Exec=cosmic-nightshift
Icon=weather-clear-night-symbolic
Terminal=false
Categories=Utility;Settings;DesktopSettings;
Keywords=night;light;shift;redshift;gamma;color;temperature;blue;warm;
StartupNotify=true
StartupWMClass=io.github.cosmic_nightshift
