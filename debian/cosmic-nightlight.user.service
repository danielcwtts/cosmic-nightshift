# Installed to /usr/lib/systemd/user/cosmic-nightlight.service by
# dh_installsystemduser. Enable per-user with:
#   systemctl --user enable --now cosmic-nightlight.service

[Unit]
Description=COSMIC Night Light background scheduler
After=graphical-session.target
PartOf=graphical-session.target

[Service]
ExecStart=/usr/bin/cosmic-nightlight --daemon
Restart=on-failure
RestartSec=5

[Install]
WantedBy=graphical-session.target
