#!/usr/bin/make -f
# SPDX-License-Identifier: MPL-2.0

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
# Keep cargo's caches inside the build tree so the build is self-contained.
export CARGO_HOME = $(CURDIR)/debian/cargo_home

DEB_DESTDIR = $(CURDIR)/debian/cosmic-nightlight

%:
	dh $@

# Build the two shipped binaries in release mode. --locked enforces the
# committed Cargo.lock. See PACKAGING.md for the vendoring needed to build
# offline (libcosmic is a git dependency).
override_dh_auto_build:
	cargo build --release --locked \
		-p nightlight-helper -p cosmic-nightlight

override_dh_auto_test:
	cargo test --release --locked -p nightlight-core

override_dh_auto_install:
	install -D -m0755 target/release/cosmic-nightlight-helper \
		$(DEB_DESTDIR)/usr/bin/cosmic-nightlight-helper
	install -D -m0755 target/release/cosmic-nightlight \
		$(DEB_DESTDIR)/usr/bin/cosmic-nightlight
	install -D -m0644 data/io.github.cosmic_nightlight.desktop \
		$(DEB_DESTDIR)/usr/share/applications/io.github.cosmic_nightlight.desktop
	install -D -m0644 data/io.github.cosmic_nightlight.settings.desktop \
		$(DEB_DESTDIR)/usr/share/applications/io.github.cosmic_nightlight.settings.desktop
	install -D -m0644 polkit/49-cosmic-nightlight.rules \
		$(DEB_DESTDIR)/usr/share/polkit-1/rules.d/49-cosmic-nightlight.rules

override_dh_auto_clean:
	rm -rf target debian/cargo_home
